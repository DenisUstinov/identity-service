COMPOSE_PROJECT_NAME=identity

SERVICE_NAME=identity
DEBUG=True
HOST=0.0.0.0
PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=identity_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_generate_secure_password

SECRET_KEY=changeme_generate_32_byte_hex_key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_OUTPUT=stdout

NOTIFICATION_SERVICE_URL: str = "http://notification-service:8001/api/v1"
NOTIFICATION_API_KEY: str = "changeme_generate_32_byte_hex_key"
